# Port for the express server
PORT=3000

# Google OAuth Credentials (Get these from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JSON Web Token Secret (Change this to a random string in production)
JWT_SECRET=some-very-secret-key-change-me

# PostgreSQL Connection String (Railway provides this automatically when you add Postgres)
# Leave blank for local development to use SQLite fallback
DATABASE_URL=
